{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ipo.one/v2/mandate.schema.json",
  "title": "IPO.ONE Mandate v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "mandateId",
    "mandateHash",
    "principalId",
    "subjectId",
    "capabilities",
    "allowedProviderIds",
    "allowedCategories",
    "assetIds",
    "perActionLimitMinor",
    "aggregateLimitMinor",
    "utilizedMinor",
    "validFrom",
    "expiresAt",
    "nonce",
    "termsRef",
    "status",
    "createdAt",
    "updatedAt",
    "schemaVersion"
  ],
  "properties": {
    "mandateId": { "type": "string", "minLength": 1 },
    "mandateHash": { "type": "string", "pattern": "^0x[0-9a-f]{64}$" },
    "principalId": { "type": "string", "minLength": 1 },
    "subjectId": { "type": "string", "minLength": 1 },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "enum": ["request_credit", "provider_spend", "capture_revenue", "route_repayment"] }
    },
    "allowedProviderIds": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "allowedCategories": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "assetIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "perActionLimitMinor": { "type": "string", "pattern": "^[1-9][0-9]*$" },
    "aggregateLimitMinor": { "type": "string", "pattern": "^[1-9][0-9]*$" },
    "utilizedMinor": { "type": "string", "pattern": "^[0-9]+$" },
    "validFrom": { "type": "string", "format": "date-time" },
    "expiresAt": { "type": "string", "format": "date-time" },
    "nonce": { "type": "string", "minLength": 1 },
    "termsRef": { "type": "string", "minLength": 1 },
    "status": { "enum": ["draft", "active", "suspended", "revoked", "expired"] },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "schemaVersion": { "const": "mandate.v2" }
  }
}
