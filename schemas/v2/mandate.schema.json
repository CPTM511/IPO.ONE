{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ipo.one/v2/mandate.schema.json",
  "title": "IPO.ONE Mandate v3",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "mandateId",
    "mandateHash",
    "termsHash",
    "principalId",
    "subjectId",
    "capabilities",
    "allowedProviderIds",
    "allowedCategories",
    "assetIds",
    "perActionLimitMinor",
    "aggregateLimitMinor",
    "utilizedMinor",
    "validFrom",
    "expiresAt",
    "nonce",
    "termsRef",
    "sandboxOnly",
    "productionAuthority",
    "status",
    "createdAt",
    "updatedAt",
    "schemaVersion"
  ],
  "properties": {
    "mandateId": { "type": "string", "minLength": 1 },
    "mandateHash": { "type": "string", "pattern": "^0x[0-9a-f]{64}$" },
    "principalId": { "type": "string", "minLength": 1 },
    "subjectId": { "type": "string", "minLength": 1 },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "enum": ["request_credit", "accept_credit_offer", "execute_sandbox_credit", "provider_spend", "capture_revenue", "route_repayment"] }
    },
    "allowedProviderIds": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "allowedCategories": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "assetIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "perActionLimitMinor": { "type": "string", "pattern": "^[1-9][0-9]*$" },
    "aggregateLimitMinor": { "type": "string", "pattern": "^[1-9][0-9]*$" },
    "utilizedMinor": { "type": "string", "pattern": "^[0-9]+$" },
    "validFrom": { "type": "string", "format": "date-time" },
    "expiresAt": { "type": "string", "format": "date-time" },
    "nonce": { "type": "string", "minLength": 1 },
    "termsRef": { "type": "string", "minLength": 1 },
    "termsHash": { "type": "string", "pattern": "^0x[0-9a-f]{64}$" },
    "sandboxOnly": { "const": true },
    "productionAuthority": { "const": false },
    "activationAcknowledgement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "expectedMandateHash",
        "acknowledgedTermsHash",
        "acknowledgementCode",
        "activatedByActorId",
        "activatedAt",
        "evidenceHash"
      ],
      "properties": {
        "expectedMandateHash": { "type": "string", "pattern": "^0x[0-9a-f]{64}$" },
        "acknowledgedTermsHash": { "type": "string", "pattern": "^0x[0-9a-f]{64}$" },
        "acknowledgementCode": { "const": "principal_authorizes_sandbox_credit_v1" },
        "activatedByActorId": { "type": "string", "minLength": 1, "maxLength": 256 },
        "activatedAt": { "type": "string", "format": "date-time" },
        "evidenceHash": { "type": "string", "pattern": "^0x[0-9a-f]{64}$" }
      }
    },
    "status": { "enum": ["draft", "active", "suspended", "revoked", "expired"] },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "schemaVersion": { "const": "mandate.v3" }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "enum": ["active", "suspended"] } } },
      "then": { "required": ["activationAcknowledgement"] }
    }
  ]
}
