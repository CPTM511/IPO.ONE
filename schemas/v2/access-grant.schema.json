{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ipo.one/v2/access-grant.schema.json",
  "title": "IPO.ONE AccessGrant v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "accessGrantId",
    "tenantId",
    "granteeTenantId",
    "granteeActorId",
    "capability",
    "resourceType",
    "resourceId",
    "purpose",
    "createdByActorId",
    "policyVersion",
    "status",
    "validFrom",
    "expiresAt",
    "version",
    "createdAt",
    "updatedAt",
    "schemaVersion"
  ],
  "properties": {
    "accessGrantId": { "type": "string", "minLength": 2, "maxLength": 256 },
    "tenantId": { "type": "string", "minLength": 2, "maxLength": 256 },
    "granteeTenantId": { "type": "string", "minLength": 2, "maxLength": 256 },
    "granteeActorId": { "type": "string", "minLength": 2, "maxLength": 256 },
    "capability": {
      "enum": [
        "provider_intent_delivery",
        "scoped_audit_read",
        "platform_reconciliation_read"
      ]
    },
    "resourceType": { "type": "string", "minLength": 2, "maxLength": 256 },
    "resourceId": { "type": "string", "minLength": 2, "maxLength": 256 },
    "purpose": { "type": "string", "pattern": "^[a-z][a-z0-9_.:-]{1,127}$" },
    "createdByActorId": { "type": "string", "minLength": 2, "maxLength": 256 },
    "policyVersion": { "type": "string", "minLength": 2, "maxLength": 256 },
    "status": { "enum": ["active", "revoked", "expired"] },
    "validFrom": { "type": "string", "format": "date-time" },
    "expiresAt": { "type": "string", "format": "date-time" },
    "revokedAt": { "type": "string", "format": "date-time" },
    "version": { "type": "integer", "minimum": 1 },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "schemaVersion": { "const": "access_grant.v1" }
  }
}
