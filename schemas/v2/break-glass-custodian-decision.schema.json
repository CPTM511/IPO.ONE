{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ipo.one/v2/break-glass-custodian-decision.schema.json",
  "title": "IPO.ONE Break Glass Custodian Decision v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "breakGlassCustodianDecisionId",
    "decisionHash",
    "tenantId",
    "breakGlassIncidentId",
    "incidentVersion",
    "incidentHash",
    "custodianActorId",
    "custodianClientId",
    "custodianCredentialId",
    "custodianCredentialVersion",
    "hardwareKeyRefHash",
    "authTime",
    "authenticationMethods",
    "version",
    "createdAt",
    "schemaVersion"
  ],
  "properties": {
    "breakGlassCustodianDecisionId": { "$ref": "#/$defs/identifier" },
    "decisionHash": { "$ref": "#/$defs/contentHash" },
    "tenantId": { "$ref": "#/$defs/identifier" },
    "breakGlassIncidentId": { "$ref": "#/$defs/identifier" },
    "incidentVersion": { "type": "integer", "minimum": 1 },
    "incidentHash": { "$ref": "#/$defs/contentHash" },
    "custodianActorId": { "$ref": "#/$defs/identifier" },
    "custodianClientId": { "$ref": "#/$defs/identifier" },
    "custodianCredentialId": { "$ref": "#/$defs/identifier" },
    "custodianCredentialVersion": { "type": "integer", "minimum": 1 },
    "hardwareKeyRefHash": { "$ref": "#/$defs/referenceHash" },
    "authTime": { "$ref": "#/$defs/timestamp" },
    "authenticationMethods": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "uniqueItems": true,
      "contains": { "enum": ["hwk", "webauthn", "fido"] },
      "items": { "$ref": "#/$defs/identifier" }
    },
    "version": { "const": 1 },
    "createdAt": { "$ref": "#/$defs/timestamp" },
    "schemaVersion": { "const": "break_glass_custodian_decision.v1" }
  },
  "$defs": {
    "identifier": { "type": "string", "minLength": 2, "maxLength": 256 },
    "contentHash": { "type": "string", "pattern": "^0x[0-9a-f]{64}$" },
    "referenceHash": {
      "type": "string",
      "minLength": 32,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9_-]+$"
    },
    "timestamp": { "type": "string", "format": "date-time" }
  }
}
