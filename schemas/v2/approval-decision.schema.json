{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ipo.one/v2/approval-decision.schema.json",
  "title": "IPO.ONE Approval Decision v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "approvalDecisionId",
    "decisionHash",
    "tenantId",
    "approvalProposalId",
    "proposalVersion",
    "proposalHash",
    "commandHash",
    "policyVersion",
    "decision",
    "reasonCode",
    "approverActorId",
    "approverActorType",
    "approverClientId",
    "approverCredentialId",
    "approverCredentialVersion",
    "approverMembershipId",
    "approverMembershipVersion",
    "approverRoleBundle",
    "authTime",
    "authenticationMethods",
    "tokenJtiHash",
    "version",
    "createdAt",
    "schemaVersion"
  ],
  "properties": {
    "approvalDecisionId": { "$ref": "#/$defs/identifier" },
    "decisionHash": { "$ref": "#/$defs/contentHash" },
    "tenantId": { "$ref": "#/$defs/identifier" },
    "approvalProposalId": { "$ref": "#/$defs/identifier" },
    "proposalVersion": { "type": "integer", "minimum": 1 },
    "proposalHash": { "$ref": "#/$defs/contentHash" },
    "commandHash": { "$ref": "#/$defs/contentHash" },
    "policyVersion": { "$ref": "#/$defs/identifier" },
    "decision": { "enum": ["approve", "reject"] },
    "reasonCode": { "$ref": "#/$defs/reasonCode" },
    "approverActorId": { "$ref": "#/$defs/identifier" },
    "approverActorType": {
      "enum": ["risk_operator", "operations_operator"]
    },
    "approverClientId": { "$ref": "#/$defs/identifier" },
    "approverCredentialId": { "$ref": "#/$defs/identifier" },
    "approverCredentialVersion": { "type": "integer", "minimum": 1 },
    "approverMembershipId": { "$ref": "#/$defs/identifier" },
    "approverMembershipVersion": { "type": "integer", "minimum": 1 },
    "approverRoleBundle": { "enum": ["risk_operator", "operations_operator"] },
    "authTime": { "$ref": "#/$defs/timestamp" },
    "authenticationMethods": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "uniqueItems": true,
      "contains": { "enum": ["hwk", "webauthn", "fido"] },
      "items": { "$ref": "#/$defs/identifier" }
    },
    "tokenJtiHash": { "$ref": "#/$defs/referenceHash" },
    "version": { "const": 1 },
    "createdAt": { "$ref": "#/$defs/timestamp" },
    "schemaVersion": { "const": "approval_decision.v1" }
  },
  "allOf": [
    {
      "if": { "properties": { "decision": { "const": "approve" } }, "required": ["decision"] },
      "then": { "properties": { "reasonCode": { "const": "approval_confirmed" } } }
    },
    {
      "if": { "properties": { "decision": { "const": "reject" } }, "required": ["decision"] },
      "then": { "properties": { "reasonCode": { "const": "approval_rejected" } } }
    }
  ],
  "$defs": {
    "identifier": { "type": "string", "minLength": 2, "maxLength": 256 },
    "contentHash": { "type": "string", "pattern": "^0x[0-9a-f]{64}$" },
    "referenceHash": {
      "type": "string",
      "minLength": 32,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9_-]+$"
    },
    "reasonCode": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,95}$" },
    "timestamp": { "type": "string", "format": "date-time" }
  }
}
