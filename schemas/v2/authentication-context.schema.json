{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ipo.one/v2/authentication-context.schema.json",
  "title": "IPO.ONE Authentication Context v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tenantId",
    "actorId",
    "actorType",
    "clientId",
    "credentialId",
    "policyVersion",
    "capabilities",
    "roles",
    "tokenJtiHash",
    "authenticationMethod",
    "senderConstraintMethod",
    "authenticatedAt",
    "amr",
    "authorizationDecision",
    "schemaVersion"
  ],
  "properties": {
    "tenantId": { "type": "string", "minLength": 2, "maxLength": 256 },
    "actorId": { "type": "string", "minLength": 2, "maxLength": 256 },
    "actorType": {
      "enum": [
        "human",
        "agent",
        "provider",
        "risk_operator",
        "operations_operator",
        "auditor",
        "system_worker"
      ]
    },
    "clientId": { "type": "string", "minLength": 2, "maxLength": 256 },
    "credentialId": { "type": "string", "minLength": 2, "maxLength": 256 },
    "policyVersion": { "type": "string", "minLength": 2, "maxLength": 256 },
    "capabilities": {
      "type": "array",
      "maxItems": 64,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_.:-]{1,127}$" }
    },
    "roles": {
      "type": "array",
      "maxItems": 16,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_.:-]{1,127}$" }
    },
    "tokenJtiHash": { "type": "string", "minLength": 32, "maxLength": 128 },
    "authenticationMethod": {
      "enum": ["oidc_pkce_bff", "private_key_jwt", "mtls"]
    },
    "senderConstraintMethod": {
      "enum": ["host_session", "dpop", "mtls"]
    },
    "authenticatedAt": { "type": "string", "format": "date-time" },
    "authTime": { "type": "string", "format": "date-time" },
    "acr": { "type": "string", "minLength": 1, "maxLength": 128 },
    "amr": {
      "type": "array",
      "maxItems": 8,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 128 }
    },
    "authorizationDecision": { "const": "not_evaluated" },
    "schemaVersion": { "const": "authentication_context.v1" }
  }
}
