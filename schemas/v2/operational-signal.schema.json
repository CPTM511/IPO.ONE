{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ipo.one/v2/operational-signal.schema.json",
  "title": "IPO.ONE Operational Signal v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "signalType",
    "sourceSystem",
    "sourceEventType",
    "sourceRefHash",
    "scopeRefHash",
    "observedAt",
    "environment",
    "sandboxOnly",
    "productionFundsMoved",
    "schemaVersion"
  ],
  "properties": {
    "signalType": {
      "enum": [
        "reconciliation_failed",
        "chain_payment_invalidated",
        "break_glass_activated",
        "admission_control_unavailable",
        "synthetic_lifecycle_failed",
        "servicing_defaulted",
        "servicing_written_off"
      ]
    },
    "sourceSystem": {
      "enum": [
        "ipo.one.credit-events.v1",
        "ipo.one.evidence.v2",
        "ipo.one.abuse-telemetry.v1",
        "ipo.one.synthetic-monitor.v1"
      ]
    },
    "sourceEventType": {
      "type": "string",
      "minLength": 2,
      "maxLength": 128,
      "pattern": "^[a-z][a-z0-9_.-]+$"
    },
    "sourceRefHash": { "$ref": "#/$defs/contentHash" },
    "scopeRefHash": { "$ref": "#/$defs/contentHash" },
    "observedAt": { "$ref": "#/$defs/timestamp" },
    "environment": { "const": "closed-pilot" },
    "sandboxOnly": { "const": true },
    "productionFundsMoved": { "const": false },
    "schemaVersion": { "const": "operational_signal.v1" }
  },
  "$defs": {
    "contentHash": { "type": "string", "pattern": "^0x[0-9a-f]{64}$" },
    "timestamp": { "type": "string", "format": "date-time" }
  }
}
