{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ipo.one/v2/evidence-event.schema.json",
  "title": "IPO.ONE Evidence Event v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "evidenceId",
    "evidenceHash",
    "eventId",
    "eventType",
    "aggregateType",
    "aggregateId",
    "aggregateVersion",
    "correlationId",
    "idempotencyKey",
    "actorRef",
    "sourceSystem",
    "sourceFinality",
    "payloadHash",
    "payload",
    "attestationRefs",
    "occurredAt",
    "recordedAt",
    "schemaVersion"
  ],
  "properties": {
    "evidenceId": { "type": "string", "minLength": 1 },
    "evidenceHash": { "type": "string", "pattern": "^0x[0-9a-f]{64}$" },
    "eventId": { "type": "string", "minLength": 1 },
    "eventType": { "type": "string", "minLength": 1 },
    "aggregateType": { "type": "string", "minLength": 1 },
    "aggregateId": { "type": "string", "minLength": 1 },
    "aggregateVersion": { "type": "integer", "minimum": 1 },
    "subjectId": { "type": "string", "minLength": 1 },
    "obligationId": { "type": "string", "minLength": 1 },
    "causationId": { "type": "string", "minLength": 1 },
    "correlationId": { "type": "string", "minLength": 1 },
    "idempotencyKey": { "type": "string", "minLength": 1 },
    "actorRef": { "type": "string", "minLength": 1 },
    "sourceSystem": { "type": "string", "minLength": 1 },
    "sourceFinality": { "enum": ["pending", "confirmed", "finalized", "reorged", "invalidated"] },
    "payloadHash": { "type": "string", "pattern": "^0x[0-9a-f]{64}$" },
    "payloadRef": { "type": "string", "minLength": 1 },
    "payload": { "type": "object" },
    "attestationRefs": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "occurredAt": { "type": "string", "format": "date-time" },
    "recordedAt": { "type": "string", "format": "date-time" },
    "schemaVersion": { "const": "evidence_event.v2" }
  }
}
