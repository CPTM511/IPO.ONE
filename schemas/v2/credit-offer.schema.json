{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ipo.one/v2/credit-offer.schema.json",
  "title": "IPO.ONE Credit Offer v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "creditOfferId",
    "creditOfferHash",
    "termsHash",
    "creditIntentId",
    "subjectId",
    "riskDecisionId",
    "assetId",
    "approvedPrincipalMinor",
    "annualRateBps",
    "originationFeeMinor",
    "repaymentFrequency",
    "installmentCount",
    "firstPaymentAt",
    "maturityAt",
    "disclosureRef",
    "termsVersion",
    "validUntil",
    "reasonCodes",
    "sandboxOnly",
    "productionFundsApproved",
    "status",
    "createdAt",
    "updatedAt",
    "schemaVersion"
  ],
  "properties": {
    "creditOfferId": { "type": "string", "minLength": 1 },
    "creditOfferHash": { "$ref": "#/$defs/hash" },
    "termsHash": { "$ref": "#/$defs/hash" },
    "creditIntentId": { "type": "string", "minLength": 1 },
    "subjectId": { "type": "string", "minLength": 1 },
    "riskDecisionId": { "type": "string", "minLength": 1 },
    "assetId": { "type": "string", "minLength": 1 },
    "approvedPrincipalMinor": { "type": "string", "pattern": "^[1-9][0-9]*$", "maxLength": 78 },
    "annualRateBps": { "type": "integer", "minimum": 0, "maximum": 100000 },
    "originationFeeMinor": { "type": "string", "pattern": "^(0|[1-9][0-9]*)$", "maxLength": 78 },
    "repaymentFrequency": { "enum": ["weekly", "biweekly", "monthly", "end_of_term"] },
    "installmentCount": { "type": "integer", "minimum": 1, "maximum": 520 },
    "firstPaymentAt": { "type": "string", "format": "date-time" },
    "maturityAt": { "type": "string", "format": "date-time" },
    "disclosureRef": { "type": "string", "minLength": 1 },
    "termsVersion": { "const": "credit_terms.v1" },
    "validUntil": { "type": "string", "format": "date-time" },
    "reasonCodes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]{1,95}$" }
    },
    "sandboxOnly": { "const": true },
    "productionFundsApproved": { "const": false },
    "status": { "enum": ["offered", "accepted", "declined", "expired", "superseded"] },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "schemaVersion": { "const": "credit_offer.v1" }
  },
  "$defs": {
    "hash": { "type": "string", "pattern": "^0x[0-9a-f]{64}$" }
  }
}
