{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ipo.one/v2/consent-record.schema.json",
  "title": "IPO.ONE Consent Record v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "consentId",
    "consentHash",
    "termsHash",
    "dataUsageHash",
    "subjectId",
    "principalId",
    "purposes",
    "allowedAssetIds",
    "allowedCreditPurposeCodes",
    "allowedRepaymentFrequencies",
    "maxRequestedPrincipalMinor",
    "maxRequestedTermDays",
    "maxInstallmentCount",
    "termsRef",
    "termsVersion",
    "dataUsageRef",
    "dataUsageVersion",
    "disclosureRef",
    "validFrom",
    "expiresAt",
    "sandboxOnly",
    "productionAuthority",
    "status",
    "createdAt",
    "updatedAt",
    "schemaVersion"
  ],
  "properties": {
    "consentId": { "type": "string", "minLength": 1 },
    "consentHash": { "$ref": "#/$defs/hash" },
    "termsHash": { "$ref": "#/$defs/hash" },
    "dataUsageHash": { "$ref": "#/$defs/hash" },
    "subjectId": { "type": "string", "minLength": 1 },
    "principalId": { "type": "string", "minLength": 1 },
    "purposes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "uniqueItems": true,
      "contains": { "const": "credit_application" },
      "items": {
        "enum": [
          "credit_application",
          "credit_decision",
          "credit_offer_acceptance",
          "identity_reference_use",
          "obligation_servicing",
          "evidence_sharing"
        ]
      }
    },
    "allowedAssetIds": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 2048 }
    },
    "allowedCreditPurposeCodes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/code" }
    },
    "allowedRepaymentFrequencies": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "uniqueItems": true,
      "items": { "enum": ["weekly", "biweekly", "monthly", "end_of_term"] }
    },
    "maxRequestedPrincipalMinor": { "type": "string", "pattern": "^[1-9][0-9]*$", "maxLength": 78 },
    "maxRequestedTermDays": { "type": "integer", "minimum": 1, "maximum": 3660 },
    "maxInstallmentCount": { "type": "integer", "minimum": 1, "maximum": 520 },
    "termsRef": { "$ref": "#/$defs/reference" },
    "termsVersion": { "$ref": "#/$defs/version" },
    "dataUsageRef": { "$ref": "#/$defs/reference" },
    "dataUsageVersion": { "$ref": "#/$defs/version" },
    "disclosureRef": { "$ref": "#/$defs/reference" },
    "validFrom": { "type": "string", "format": "date-time" },
    "expiresAt": { "type": "string", "format": "date-time" },
    "sandboxOnly": { "const": true },
    "productionAuthority": { "const": false },
    "status": { "enum": ["active", "revoked", "expired"] },
    "revokedAt": { "type": "string", "format": "date-time" },
    "revocationReasonCode": { "$ref": "#/$defs/code" },
    "revocationEvidenceRef": { "$ref": "#/$defs/reference" },
    "expiredAt": { "type": "string", "format": "date-time" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "schemaVersion": { "const": "consent_record.v1" }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "active" } } },
      "then": { "not": { "anyOf": [
        { "required": ["revokedAt"] },
        { "required": ["revocationReasonCode"] },
        { "required": ["revocationEvidenceRef"] },
        { "required": ["expiredAt"] }
      ] } }
    },
    {
      "if": { "properties": { "status": { "const": "revoked" } } },
      "then": {
        "required": ["revokedAt", "revocationReasonCode", "revocationEvidenceRef"],
        "not": { "required": ["expiredAt"] }
      }
    },
    {
      "if": { "properties": { "status": { "const": "expired" } } },
      "then": {
        "required": ["expiredAt"],
        "not": { "anyOf": [
          { "required": ["revokedAt"] },
          { "required": ["revocationReasonCode"] },
          { "required": ["revocationEvidenceRef"] }
        ] }
      }
    }
  ],
  "$defs": {
    "hash": { "type": "string", "pattern": "^0x[0-9a-f]{64}$" },
    "code": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]{1,95}$" },
    "version": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]{0,95}\\.v[1-9][0-9]*$" },
    "reference": { "type": "string", "minLength": 1, "maxLength": 2048 }
  }
}
