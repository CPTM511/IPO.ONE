{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ipo.one/v2/membership.schema.json",
  "title": "IPO.ONE Membership v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "membershipId",
    "tenantId",
    "actorId",
    "actorType",
    "roleBundle",
    "capabilities",
    "clientIds",
    "policyVersion",
    "status",
    "validFrom",
    "version",
    "createdAt",
    "updatedAt",
    "schemaVersion"
  ],
  "properties": {
    "membershipId": { "type": "string", "minLength": 2, "maxLength": 256 },
    "tenantId": { "type": "string", "minLength": 2, "maxLength": 256 },
    "actorId": { "type": "string", "minLength": 2, "maxLength": 256 },
    "actorType": {
      "enum": [
        "human",
        "agent",
        "provider",
        "risk_operator",
        "operations_operator",
        "auditor",
        "system_worker"
      ]
    },
    "roleBundle": {
      "enum": [
        "tenant_owner",
        "developer",
        "principal_controller",
        "human_borrower",
        "agent_runtime",
        "risk_operator",
        "operations_operator",
        "auditor",
        "provider_service",
        "system_worker"
      ]
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_.:-]{1,127}$" }
    },
    "clientIds": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 2, "maxLength": 256 }
    },
    "policyVersion": { "type": "string", "minLength": 2, "maxLength": 256 },
    "status": { "enum": ["active", "suspended", "revoked", "expired"] },
    "validFrom": { "type": "string", "format": "date-time" },
    "expiresAt": { "type": "string", "format": "date-time" },
    "version": { "type": "integer", "minimum": 1 },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "schemaVersion": { "const": "membership.v1" }
  }
}
