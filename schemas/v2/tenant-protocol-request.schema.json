{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ipo.one/v2/tenant-protocol-request.schema.json",
  "title": "IPO.ONE Tenant Protocol Request v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "operationId",
    "payload",
    "requestId",
    "correlationId",
    "schemaVersion"
  ],
  "properties": {
    "operationId": {
      "enum": [
        "pilotCreateAgentSubject",
        "pilotCreateDraftMandate",
        "pilotReadAgentSelf",
        "pilotReadMandate",
        "pilotRevokeDraftMandate"
      ]
    },
    "payload": { "type": "object" },
    "requestId": { "$ref": "#/$defs/requestIdentifier" },
    "correlationId": { "$ref": "#/$defs/requestIdentifier" },
    "idempotencyKey": {
      "type": "string",
      "minLength": 16,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "resource": { "$ref": "#/$defs/resourceReference" },
    "reasonCode": {
      "enum": ["credential_compromise", "operator_request", "security_incident"]
    },
    "retryAttempt": { "type": "integer", "minimum": 0, "maximum": 16 },
    "schemaVersion": { "const": "tenant_protocol_request.v1" }
  },
  "oneOf": [
    {
      "title": "Create Agent Subject",
      "required": ["idempotencyKey"],
      "properties": {
        "operationId": { "const": "pilotCreateAgentSubject" },
        "payload": { "$ref": "#/$defs/createAgentSubjectPayload" }
      },
      "not": {
        "anyOf": [
          { "required": ["resource"] },
          { "required": ["reasonCode"] }
        ]
      }
    },
    {
      "title": "Create Draft Mandate",
      "required": ["idempotencyKey", "resource"],
      "properties": {
        "operationId": { "const": "pilotCreateDraftMandate" },
        "payload": { "$ref": "#/$defs/createDraftMandatePayload" },
        "resource": { "$ref": "#/$defs/subjectResourceReference" }
      },
      "not": { "required": ["reasonCode"] }
    },
    {
      "title": "Read Agent Self",
      "required": ["resource"],
      "properties": {
        "operationId": { "const": "pilotReadAgentSelf" },
        "payload": { "$ref": "#/$defs/emptyPayload" },
        "resource": { "$ref": "#/$defs/subjectResourceReference" }
      },
      "not": {
        "anyOf": [
          { "required": ["idempotencyKey"] },
          { "required": ["reasonCode"] }
        ]
      }
    },
    {
      "title": "Read Mandate",
      "required": ["resource"],
      "properties": {
        "operationId": { "const": "pilotReadMandate" },
        "payload": { "$ref": "#/$defs/emptyPayload" },
        "resource": { "$ref": "#/$defs/mandateResourceReference" }
      },
      "not": {
        "anyOf": [
          { "required": ["idempotencyKey"] },
          { "required": ["reasonCode"] }
        ]
      }
    },
    {
      "title": "Revoke Draft Mandate",
      "required": ["idempotencyKey", "resource", "reasonCode"],
      "properties": {
        "operationId": { "const": "pilotRevokeDraftMandate" },
        "payload": { "$ref": "#/$defs/emptyPayload" },
        "resource": { "$ref": "#/$defs/mandateResourceReference" }
      }
    }
  ],
  "$defs": {
    "requestIdentifier": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "domainIdentifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9:._/%-]*$"
    },
    "resourceReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["resourceType", "resourceId"],
      "properties": {
        "resourceType": { "enum": ["subject", "mandate"] },
        "resourceId": { "$ref": "#/$defs/domainIdentifier" }
      }
    },
    "subjectResourceReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["resourceType", "resourceId"],
      "properties": {
        "resourceType": { "const": "subject" },
        "resourceId": { "$ref": "#/$defs/domainIdentifier" }
      }
    },
    "mandateResourceReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["resourceType", "resourceId"],
      "properties": {
        "resourceType": { "const": "mandate" },
        "resourceId": { "$ref": "#/$defs/domainIdentifier" }
      }
    },
    "emptyPayload": {
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 0
    },
    "createAgentSubjectPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subjectActorId", "displayName"],
      "properties": {
        "subjectActorId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
        },
        "displayName": { "type": "string", "minLength": 1, "maxLength": 120 },
        "jurisdiction": {
          "type": "string",
          "minLength": 1,
          "maxLength": 32,
          "pattern": "^[A-Z][A-Z0-9-]*$"
        }
      }
    },
    "createDraftMandatePayload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capabilities",
        "allowedProviderIds",
        "allowedCategories",
        "assetIds",
        "perActionLimitMinor",
        "aggregateLimitMinor",
        "validFrom",
        "expiresAt",
        "nonce",
        "termsRef"
      ],
      "properties": {
        "capabilities": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "uniqueItems": true,
          "items": {
            "enum": [
              "request_credit",
              "provider_spend",
              "capture_revenue",
              "route_repayment"
            ]
          }
        },
        "allowedProviderIds": {
          "type": "array",
          "maxItems": 32,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/domainIdentifier" }
        },
        "allowedCategories": {
          "type": "array",
          "maxItems": 32,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/domainIdentifier" }
        },
        "assetIds": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/domainIdentifier" }
        },
        "perActionLimitMinor": {
          "type": "string",
          "minLength": 1,
          "maxLength": 78,
          "pattern": "^[1-9][0-9]*$"
        },
        "aggregateLimitMinor": {
          "type": "string",
          "minLength": 1,
          "maxLength": 78,
          "pattern": "^[1-9][0-9]*$"
        },
        "validFrom": { "$ref": "#/$defs/timestamp" },
        "expiresAt": { "$ref": "#/$defs/timestamp" },
        "nonce": {
          "type": "string",
          "minLength": 16,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
        },
        "termsRef": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512,
          "pattern": "^(https://|ipfs:|urn:)[^\\s]+$"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "capabilities": {
                "type": "array",
                "contains": { "const": "provider_spend" }
              }
            },
            "required": ["capabilities"]
          },
          "then": {
            "properties": {
              "allowedProviderIds": { "type": "array", "minItems": 1 },
              "allowedCategories": { "type": "array", "minItems": 1 }
            }
          },
          "else": {
            "properties": {
              "allowedProviderIds": { "type": "array", "maxItems": 0 },
              "allowedCategories": { "type": "array", "maxItems": 0 }
            }
          }
        }
      ]
    },
    "timestamp": {
      "type": "string",
      "minLength": 20,
      "maxLength": 64,
      "format": "date-time"
    }
  }
}
