{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ipo.one/v2/abuse-control-policy.schema.json",
  "title": "IPO.ONE Abuse Control Policy v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "policyVersion",
    "hardCeilings",
    "publicProfiles",
    "operations",
    "schemaVersion"
  ],
  "properties": {
    "policyVersion": { "const": "abuse_001.v1" },
    "hardCeilings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rate",
        "concurrency",
        "metrics",
        "resources",
        "upstreamCostUnitsPerMinute",
        "admissionLeaseMs",
        "automaticRetries"
      ],
      "properties": {
        "rate": { "$ref": "#/$defs/rateLimits" },
        "concurrency": { "$ref": "#/$defs/concurrencyLimits" },
        "metrics": { "$ref": "#/$defs/metricLimits" },
        "resources": { "$ref": "#/$defs/resourceLimits" },
        "upstreamCostUnitsPerMinute": { "type": "integer", "minimum": 0, "maximum": 1000 },
        "admissionLeaseMs": { "type": "integer", "minimum": 1, "maximum": 60000 },
        "automaticRetries": { "type": "integer", "minimum": 0, "maximum": 3 }
      }
    },
    "publicProfiles": {
      "type": "object",
      "additionalProperties": false,
      "required": ["public.discovery", "authentication.credential"],
      "properties": {
        "public.discovery": { "const": "discovery" },
        "authentication.credential": { "const": "credential" }
      }
    },
    "operations": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pilotAcceptCreditOffer",
        "pilotExecuteSandboxObligation",
        "pilotPostSandboxRepayment",
        "pilotRestructureSandboxObligation",
        "pilotRepurchaseSandboxObligation",
        "pilotWriteOffSandboxObligation",
        "pilotProposeApproval",
        "pilotReadApproval",
        "pilotDecideApproval",
        "pilotCancelApproval",
        "pilotCreateAgentSubject",
        "pilotCreateAgentAccountChallenge",
        "pilotCreateHumanSubject",
        "pilotReadHumanSelf",
        "pilotReadWorkspaceResume",
        "pilotCreateConsent",
        "pilotReadConsent",
        "pilotRevokeConsent",
        "pilotReadIdentityReference",
        "pilotCreateDraftMandate",
        "pilotActivateSandboxMandate",
        "pilotReadMandate",
        "pilotReadCreditApplication",
        "pilotEvaluateCreditApplication",
        "pilotRevokeDraftMandate",
        "pilotReadAgentSelf",
        "pilotReadAgentAccountBinding",
        "pilotRequestCredit",
        "pilotSubmitAgentAccountProof",
        "pilotSubmitSpend",
        "pilotCaptureRevenue",
        "pilotAutoRepay",
        "pilotReadTenantRisk",
        "pilotReadPilotHealth",
        "pilotReadPilotFeedbackSummary",
        "pilotSubmitPilotFeedback",
        "pilotReadServicingQueue",
        "pilotFreezeSubject",
        "pilotReduceCreditLimit",
        "pilotIncreaseCreditLimit",
        "pilotUnfreezeSubject",
        "pilotReadProviderIntent",
        "pilotAcknowledgeProviderIntent",
        "pilotReadEvidence",
        "pilotReadOwnObligation",
        "pilotReadOwnObligationEvidence",
        "pilotExportAudit",
        "workerPublishOutbox",
        "workerExpireApproval",
        "workerProcessInbox",
        "workerAdvanceSandboxServicing",
        "workerAutoRepay",
        "workerRunReconciliation",
        "workerPlanProjectionRepair",
        "workerExecuteProjectionRepair"
      ],
      "properties": {
        "pilotAcceptCreditOffer": { "const": "economic" },
        "pilotExecuteSandboxObligation": { "const": "economic" },
        "pilotPostSandboxRepayment": { "const": "economic" },
        "pilotRestructureSandboxObligation": { "const": "privileged" },
        "pilotRepurchaseSandboxObligation": { "const": "privileged" },
        "pilotWriteOffSandboxObligation": { "const": "privileged" },
        "pilotProposeApproval": { "const": "privileged" },
        "pilotReadApproval": { "const": "read" },
        "pilotDecideApproval": { "const": "privileged" },
        "pilotCancelApproval": { "const": "privileged" },
        "pilotCreateAgentSubject": { "const": "mutation" },
        "pilotCreateAgentAccountChallenge": { "const": "credential" },
        "pilotCreateHumanSubject": { "const": "mutation" },
        "pilotReadHumanSelf": { "const": "read" },
        "pilotReadWorkspaceResume": { "const": "read" },
        "pilotCreateConsent": { "const": "mutation" },
        "pilotReadConsent": { "const": "read" },
        "pilotRevokeConsent": { "const": "mutation" },
        "pilotReadIdentityReference": { "const": "read" },
        "pilotCreateDraftMandate": { "const": "mutation" },
        "pilotActivateSandboxMandate": { "const": "mutation" },
        "pilotReadMandate": { "const": "read" },
        "pilotReadCreditApplication": { "const": "read" },
        "pilotEvaluateCreditApplication": { "const": "economic" },
        "pilotRevokeDraftMandate": { "const": "mutation" },
        "pilotReadAgentSelf": { "const": "read" },
        "pilotReadAgentAccountBinding": { "const": "read" },
        "pilotRequestCredit": { "const": "economic" },
        "pilotSubmitAgentAccountProof": { "const": "credential" },
        "pilotSubmitSpend": { "const": "economic" },
        "pilotCaptureRevenue": { "const": "economic" },
        "pilotAutoRepay": { "const": "economic" },
        "pilotReadTenantRisk": { "const": "read" },
        "pilotReadPilotHealth": { "const": "read" },
        "pilotReadPilotFeedbackSummary": { "const": "read" },
        "pilotSubmitPilotFeedback": { "const": "mutation" },
        "pilotReadServicingQueue": { "const": "read" },
        "pilotFreezeSubject": { "const": "privileged" },
        "pilotReduceCreditLimit": { "const": "privileged" },
        "pilotIncreaseCreditLimit": { "const": "privileged" },
        "pilotUnfreezeSubject": { "const": "privileged" },
        "pilotReadProviderIntent": { "const": "read" },
        "pilotAcknowledgeProviderIntent": { "const": "mutation" },
        "pilotReadEvidence": { "const": "read" },
        "pilotReadOwnObligation": { "const": "read" },
        "pilotReadOwnObligationEvidence": { "const": "read" },
        "pilotExportAudit": { "const": "batch" },
        "workerPublishOutbox": { "const": "worker" },
        "workerExpireApproval": { "const": "worker" },
        "workerProcessInbox": { "const": "worker" },
        "workerAdvanceSandboxServicing": { "const": "worker" },
        "workerAutoRepay": { "const": "economic" },
        "workerRunReconciliation": { "const": "batch" },
        "workerPlanProjectionRepair": { "const": "privileged" },
        "workerExecuteProjectionRepair": { "const": "privileged" }
      }
    },
    "schemaVersion": { "const": "abuse_control_policy.v1" }
  },
  "$defs": {
    "rateLimits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "windowMs",
        "actor",
        "client",
        "tenant",
        "operation",
        "service",
        "network",
        "account"
      ],
      "properties": {
        "windowMs": { "type": "integer", "minimum": 1000, "maximum": 600000 },
        "actor": { "type": "integer", "minimum": 0, "maximum": 2000 },
        "client": { "type": "integer", "minimum": 0, "maximum": 5000 },
        "tenant": { "type": "integer", "minimum": 0, "maximum": 10000 },
        "operation": { "type": "integer", "minimum": 0, "maximum": 5000 },
        "service": { "type": "integer", "minimum": 0, "maximum": 25000 },
        "network": { "type": "integer", "minimum": 0, "maximum": 5000 },
        "account": { "type": "integer", "minimum": 0, "maximum": 100 }
      }
    },
    "concurrencyLimits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actor", "tenant", "service"],
      "properties": {
        "actor": { "type": "integer", "minimum": 0, "maximum": 16 },
        "tenant": { "type": "integer", "minimum": 0, "maximum": 64 },
        "service": { "type": "integer", "minimum": 0, "maximum": 256 }
      }
    },
    "metricLimits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bodyBytes",
        "commandBytes",
        "eventBytes",
        "projectionBytes",
        "projectionWriteSetBytes",
        "responseBytes",
        "exportRows",
        "queueUnits",
        "executionMs",
        "upstreamCostUnits"
      ],
      "properties": {
        "bodyBytes": { "type": "integer", "minimum": 0, "maximum": 65536 },
        "commandBytes": { "type": "integer", "minimum": 0, "maximum": 1048576 },
        "eventBytes": { "type": "integer", "minimum": 0, "maximum": 65536 },
        "projectionBytes": { "type": "integer", "minimum": 0, "maximum": 131072 },
        "projectionWriteSetBytes": { "type": "integer", "minimum": 0, "maximum": 2097152 },
        "responseBytes": { "type": "integer", "minimum": 0, "maximum": 262144 },
        "exportRows": { "type": "integer", "minimum": 0, "maximum": 10000 },
        "queueUnits": { "type": "integer", "minimum": 0, "maximum": 16 },
        "executionMs": { "type": "integer", "minimum": 0, "maximum": 30000 },
        "upstreamCostUnits": { "type": "integer", "minimum": 0, "maximum": 100 }
      }
    },
    "resourceLimits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "agent_subjects",
        "mandates",
        "credit_intents",
        "credit_decisions",
        "open_obligations",
        "providers",
        "credentials",
        "access_grants"
      ],
      "properties": {
        "agent_subjects": { "type": "integer", "minimum": 0, "maximum": 500 },
        "mandates": { "type": "integer", "minimum": 0, "maximum": 1000 },
        "credit_intents": { "type": "integer", "minimum": 0, "maximum": 1000 },
        "credit_decisions": { "type": "integer", "minimum": 0, "maximum": 1000 },
        "open_obligations": { "type": "integer", "minimum": 0, "maximum": 1000 },
        "providers": { "type": "integer", "minimum": 0, "maximum": 100 },
        "credentials": { "type": "integer", "minimum": 0, "maximum": 50 },
        "access_grants": { "type": "integer", "minimum": 0, "maximum": 500 }
      }
    }
  }
}
