{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ipo.one/v2/authorization-decision.schema.json",
  "title": "IPO.ONE Authorization Decision v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "decisionId",
    "tenantId",
    "actorId",
    "actorType",
    "clientId",
    "credentialId",
    "operationId",
    "action",
    "resourceType",
    "resourceId",
    "authorizationDecision",
    "policyVersion",
    "requiredCapability",
    "membershipId",
    "membershipVersion",
    "revalidationCount",
    "resourceVersion",
    "liveStateVersion",
    "tokenJtiHash",
    "authorizationRequestHash",
    "commandHash",
    "approvalIds",
    "authorizedAt",
    "expiresAt",
    "schemaVersion"
  ],
  "properties": {
    "decisionId": { "type": "string", "minLength": 2, "maxLength": 256 },
    "tenantId": { "type": "string", "minLength": 2, "maxLength": 256 },
    "actorId": { "type": "string", "minLength": 2, "maxLength": 256 },
    "actorType": {
      "enum": [
        "human",
        "agent",
        "provider",
        "risk_operator",
        "operations_operator",
        "auditor",
        "system_worker"
      ]
    },
    "clientId": { "type": "string", "minLength": 2, "maxLength": 256 },
    "credentialId": { "type": "string", "minLength": 2, "maxLength": 256 },
    "operationId": { "type": "string", "minLength": 2, "maxLength": 256 },
    "action": { "type": "string", "minLength": 2, "maxLength": 256 },
    "resourceType": { "type": "string", "minLength": 2, "maxLength": 256 },
    "resourceId": { "type": "string", "minLength": 2, "maxLength": 256 },
    "authorizationDecision": { "const": "allow" },
    "policyVersion": { "type": "string", "minLength": 2, "maxLength": 256 },
    "requiredCapability": { "type": "string", "pattern": "^[a-z][a-z0-9_.:-]{1,127}$" },
    "membershipId": { "type": "string", "minLength": 2, "maxLength": 256 },
    "membershipVersion": { "type": "integer", "minimum": 1 },
    "revalidationCount": { "type": "integer", "minimum": 0 },
    "resourceVersion": { "type": "integer", "minimum": 0 },
    "liveStateVersion": { "type": "integer", "minimum": 0 },
    "accessGrantId": { "type": "string", "minLength": 2, "maxLength": 256 },
    "accessGrantVersion": { "type": "integer", "minimum": 1 },
    "tokenJtiHash": {
      "type": "string",
      "minLength": 32,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9_-]+$"
    },
    "authorizationRequestHash": {
      "type": "string",
      "minLength": 32,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9_-]+$"
    },
    "commandHash": { "type": "string", "pattern": "^0x[0-9a-f]{64}$" },
    "idempotencyKeyHash": {
      "type": "string",
      "minLength": 32,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9_-]+$"
    },
    "approvalIds": {
      "type": "array",
      "maxItems": 8,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 2, "maxLength": 256 }
    },
    "authorizedAt": { "type": "string", "format": "date-time" },
    "expiresAt": { "type": "string", "format": "date-time" },
    "schemaVersion": { "const": "authorization_decision.v1" }
  },
  "dependentRequired": {
    "accessGrantId": ["accessGrantVersion"],
    "accessGrantVersion": ["accessGrantId"]
  }
}
