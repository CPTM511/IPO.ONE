{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ipo.one/v2/tenant-protocol-catalog.schema.json",
  "title": "IPO.ONE Tenant Protocol Catalog v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol",
    "protocolVersion",
    "maturity",
    "availability",
    "compatibility",
    "operations",
    "safety",
    "schemaVersion"
  ],
  "properties": {
    "protocol": { "const": "IPO.ONE" },
    "protocolVersion": { "const": "tenant_protocol.v1" },
    "maturity": { "const": "local_non_funds" },
    "availability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabledTransports",
        "publicEndpointEnabled",
        "authenticatedHttpEnabled",
        "mcpA2aEnabled",
        "authenticationContextSource",
        "networkContextSource"
      ],
      "properties": {
        "enabledTransports": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "uniqueItems": true,
          "items": { "const": "local_in_process" }
        },
        "publicEndpointEnabled": { "const": false },
        "authenticatedHttpEnabled": { "const": false },
        "mcpA2aEnabled": { "const": false },
        "authenticationContextSource": { "const": "trusted_transport_adapter" },
        "networkContextSource": { "const": "trusted_ingress_adapter" }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "acceptedRequestSchemaVersions",
        "emittedResultSchemaVersions",
        "unknownFieldsRejected",
        "unknownOperationsRejected",
        "breakingChangeRequiresNewSchemaVersion",
        "minimumProductionDeprecationDays"
      ],
      "properties": {
        "acceptedRequestSchemaVersions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "items": { "const": "tenant_protocol_request.v1" }
        },
        "emittedResultSchemaVersions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "items": { "const": "tenant_protocol_result.v1" }
        },
        "unknownFieldsRejected": { "const": true },
        "unknownOperationsRejected": { "const": true },
        "breakingChangeRequiresNewSchemaVersion": { "const": true },
        "minimumProductionDeprecationDays": { "const": 90 }
      }
    },
    "operations": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/operation" }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "realFundsEnabled",
        "productionCreditEnabled",
        "humanCreditEnabled",
        "mandateActivationEnabled",
        "productionIdentityEnabled",
        "rawPiiAllowed"
      ],
      "properties": {
        "realFundsEnabled": { "const": false },
        "productionCreditEnabled": { "const": false },
        "humanCreditEnabled": { "const": false },
        "mandateActivationEnabled": { "const": false },
        "productionIdentityEnabled": { "const": false },
        "rawPiiAllowed": { "const": false }
      }
    },
    "schemaVersion": { "const": "tenant_protocol_catalog.v1" }
  },
  "$defs": {
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operationId",
        "kind",
        "actorTypes",
        "resourceType",
        "requiredCapability",
        "idempotency",
        "quotaClass",
        "requestSchemaVersion",
        "responseSchemaVersion",
        "public",
        "fundsAuthority"
      ],
      "properties": {
        "operationId": {
          "enum": [
            "pilotCreateAgentSubject",
            "pilotCreateDraftMandate",
            "pilotFreezeSubject",
            "pilotReadAgentSelf",
            "pilotReadMandate",
            "pilotReadTenantRisk",
            "pilotRevokeDraftMandate"
          ]
        },
        "kind": { "enum": ["command", "query"] },
        "actorTypes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "uniqueItems": true,
          "items": {
            "enum": ["human", "agent", "risk_operator", "operations_operator", "auditor"]
          }
        },
        "resourceType": { "enum": ["subject", "mandate", "risk_portfolio"] },
        "requiredCapability": {
          "enum": [
            "agent.create",
            "integration.read.owned",
            "mandate.draft.create",
            "mandate.draft.revoke",
            "risk.read.tenant",
            "risk.freeze",
            "subject.read.self"
          ]
        },
        "idempotency": { "enum": ["required", "prohibited"] },
        "quotaClass": { "enum": ["read", "mutation", "privileged"] },
        "requestSchemaVersion": { "const": "tenant_protocol_request.v1" },
        "responseSchemaVersion": {
          "enum": [
            "tenant_agent_subject_created.v1",
            "tenant_agent_subject_frozen.v1",
            "tenant_draft_mandate_created.v1",
            "tenant_agent_subject_view.v2",
            "tenant_mandate_view.v1",
            "tenant_risk_portfolio_view.v1",
            "tenant_draft_mandate_revoked.v1"
          ]
        },
        "public": { "const": false },
        "fundsAuthority": { "const": false }
      },
      "oneOf": [
        {
          "properties": {
            "operationId": { "const": "pilotCreateAgentSubject" },
            "kind": { "const": "command" },
            "actorTypes": { "const": ["human"] },
            "resourceType": { "const": "subject" },
            "requiredCapability": { "const": "agent.create" },
            "idempotency": { "const": "required" },
            "quotaClass": { "const": "mutation" },
            "responseSchemaVersion": { "const": "tenant_agent_subject_created.v1" }
          }
        },
        {
          "properties": {
            "operationId": { "const": "pilotCreateDraftMandate" },
            "kind": { "const": "command" },
            "actorTypes": { "const": ["human"] },
            "resourceType": { "const": "subject" },
            "requiredCapability": { "const": "mandate.draft.create" },
            "idempotency": { "const": "required" },
            "quotaClass": { "const": "mutation" },
            "responseSchemaVersion": { "const": "tenant_draft_mandate_created.v1" }
          }
        },
        {
          "properties": {
            "operationId": { "const": "pilotFreezeSubject" },
            "kind": { "const": "command" },
            "actorTypes": { "const": ["risk_operator", "operations_operator"] },
            "resourceType": { "const": "subject" },
            "requiredCapability": { "const": "risk.freeze" },
            "idempotency": { "const": "required" },
            "quotaClass": { "const": "privileged" },
            "responseSchemaVersion": { "const": "tenant_agent_subject_frozen.v1" }
          }
        },
        {
          "properties": {
            "operationId": { "const": "pilotReadAgentSelf" },
            "kind": { "const": "query" },
            "actorTypes": { "const": ["agent"] },
            "resourceType": { "const": "subject" },
            "requiredCapability": { "const": "subject.read.self" },
            "idempotency": { "const": "prohibited" },
            "quotaClass": { "const": "read" },
            "responseSchemaVersion": { "const": "tenant_agent_subject_view.v2" }
          }
        },
        {
          "properties": {
            "operationId": { "const": "pilotReadMandate" },
            "kind": { "const": "query" },
            "actorTypes": { "const": ["human"] },
            "resourceType": { "const": "mandate" },
            "requiredCapability": { "const": "integration.read.owned" },
            "idempotency": { "const": "prohibited" },
            "quotaClass": { "const": "read" },
            "responseSchemaVersion": { "const": "tenant_mandate_view.v1" }
          }
        },
        {
          "properties": {
            "operationId": { "const": "pilotReadTenantRisk" },
            "kind": { "const": "query" },
            "actorTypes": { "const": ["risk_operator", "auditor"] },
            "resourceType": { "const": "risk_portfolio" },
            "requiredCapability": { "const": "risk.read.tenant" },
            "idempotency": { "const": "prohibited" },
            "quotaClass": { "const": "read" },
            "responseSchemaVersion": { "const": "tenant_risk_portfolio_view.v1" }
          }
        },
        {
          "properties": {
            "operationId": { "const": "pilotRevokeDraftMandate" },
            "kind": { "const": "command" },
            "actorTypes": { "const": ["human"] },
            "resourceType": { "const": "mandate" },
            "requiredCapability": { "const": "mandate.draft.revoke" },
            "idempotency": { "const": "required" },
            "quotaClass": { "const": "mutation" },
            "responseSchemaVersion": { "const": "tenant_draft_mandate_revoked.v1" }
          }
        }
      ]
    }
  }
}
