{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ipo.one/v2/provider-intent-view.schema.json",
  "title": "IPO.ONE Provider Intent View v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "deliveryId", "deliveryHash", "transferIntentId", "transferIntentHash",
    "providerId", "purposeCode", "sourceAssetId", "sourceAmountMinor",
    "destinationAssetId", "status", "issuedAt", "expiresAt", "sandboxOnly",
    "productionFundsMoved", "withdrawable", "schemaVersion"
  ],
  "properties": {
    "deliveryId": { "$ref": "#/$defs/identifier" },
    "deliveryHash": { "$ref": "#/$defs/hash" },
    "transferIntentId": { "$ref": "#/$defs/identifier" },
    "transferIntentHash": { "$ref": "#/$defs/hash" },
    "providerId": { "$ref": "#/$defs/identifier" },
    "purposeCode": { "$ref": "#/$defs/identifier" },
    "sourceAssetId": { "$ref": "#/$defs/identifier" },
    "sourceAmountMinor": { "type": "string", "pattern": "^[1-9][0-9]{0,77}$" },
    "destinationAssetId": { "$ref": "#/$defs/identifier" },
    "status": { "enum": ["pending", "acknowledged", "callback_completed"] },
    "issuedAt": { "type": "string", "format": "date-time" },
    "expiresAt": { "type": "string", "format": "date-time" },
    "sandboxOnly": { "const": true },
    "productionFundsMoved": { "const": false },
    "withdrawable": { "const": false },
    "schemaVersion": { "const": "provider_intent_view.v1" }
  },
  "$defs": {
    "identifier": {
      "type": "string", "minLength": 1, "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9:._/%-]{0,255}$"
    },
    "hash": { "type": "string", "pattern": "^0x[0-9a-f]{64}$" }
  }
}
