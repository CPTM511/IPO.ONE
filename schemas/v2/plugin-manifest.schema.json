{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ipo.one/v2/plugin-manifest.schema.json",
  "title": "IPO.ONE Plugin Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "pluginId",
    "manifestHash",
    "pluginKey",
    "displayName",
    "publisherId",
    "pluginType",
    "capabilities",
    "supportedSchemaVersions",
    "jurisdictions",
    "dataClasses",
    "requiredInputs",
    "producedAttestationTypes",
    "endpoint",
    "authMethod",
    "failurePolicy",
    "sandboxOnly",
    "serviceVersion",
    "termsRef",
    "status",
    "registeredAt",
    "updatedAt",
    "schemaVersion"
  ],
  "properties": {
    "pluginId": { "type": "string", "minLength": 1 },
    "manifestHash": { "type": "string", "pattern": "^0x[0-9a-f]{64}$" },
    "pluginKey": { "type": "string", "minLength": 1 },
    "displayName": { "type": "string", "minLength": 1 },
    "publisherId": { "type": "string", "minLength": 1 },
    "pluginType": { "enum": ["identity", "compliance", "payment_rail", "on_off_ramp", "provider", "attester", "chain", "risk"] },
    "capabilities": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)+$" } },
    "supportedSchemaVersions": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]*\\.v[1-9][0-9]*$" } },
    "jurisdictions": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "dataClasses": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "requiredInputs": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "producedAttestationTypes": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "endpoint": { "type": "string", "format": "uri" },
    "authMethod": { "enum": ["oauth2", "signed_request", "mtls", "none"] },
    "failurePolicy": { "enum": ["fail_closed", "queue_for_review", "deny_and_alert"] },
    "sandboxOnly": { "type": "boolean" },
    "serviceVersion": { "type": "string", "minLength": 1 },
    "termsRef": { "type": "string", "minLength": 1 },
    "status": { "enum": ["pending", "active", "suspended", "revoked"] },
    "registeredAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "schemaVersion": { "const": "plugin_manifest.v1" }
  }
}
