apiVersion: serving.knative.dev/v1
kind: Service
metadata:
  name: ipo-one-public-sandbox
  namespace: ${PROJECT_NUMBER}
  labels:
    cloud.googleapis.com/location: ${REGION}
  annotations:
    run.googleapis.com/default-url-disabled: "true"
    run.googleapis.com/ingress: internal-and-cloud-load-balancing
    run.googleapis.com/invoker-iam-disabled: "true"
    run.googleapis.com/minScale: "1"
    run.googleapis.com/maxScale: "10"
spec:
  template:
    metadata:
      annotations:
        run.googleapis.com/execution-environment: gen2
        run.googleapis.com/startup-cpu-boost: "true"
    spec:
      containerConcurrency: 20
      timeoutSeconds: 30
      serviceAccountName: ${SERVICE_ACCOUNT_EMAIL}
      containers:
        - name: ipo-one
          image: ${IMAGE_URI}
          ports:
            - name: http1
              containerPort: 8080
          env:
            - name: NODE_ENV
              value: production
            - name: IPO_ONE_ALLOWED_HOSTS
              value: ipo.one,www.ipo.one
            - name: IPO_ONE_DEPLOYMENT_MODE
              value: public_sandbox
            - name: IPO_ONE_HSTS_MAX_AGE
              value: "86400"
            - name: IPO_ONE_PUBLIC_ORIGIN
              value: https://ipo.one
            - name: IPO_ONE_PUBLIC_SANDBOX_ACK
              value: I_UNDERSTAND_NO_REAL_FUNDS
            - name: IPO_ONE_RELEASE_SHA
              value: ${RELEASE_SHA}
            - name: IPO_ONE_SECURITY_CONTACT
              value: ${SECURITY_CONTACT_URL}
            - name: IPO_ONE_TRUST_PROXY
              value: "true"
          resources:
            limits:
              cpu: "1"
              memory: 512Mi
          startupProbe:
            httpGet:
              path: /livez
              port: 8080
              httpHeaders:
                - name: Host
                  value: 127.0.0.1
            initialDelaySeconds: 0
            timeoutSeconds: 1
            failureThreshold: 15
            periodSeconds: 2
          livenessProbe:
            httpGet:
              path: /livez
              port: 8080
              httpHeaders:
                - name: Host
                  value: 127.0.0.1
            initialDelaySeconds: 10
            timeoutSeconds: 2
            failureThreshold: 3
            periodSeconds: 10
  traffic:
    - percent: 100
      latestRevision: true
