apiVersion: serving.knative.dev/v1
kind: Service
metadata:
  name: ipo-one-closed-pilot
  namespace: ${PROJECT_NUMBER}
  labels:
    cloud.googleapis.com/location: ${REGION}
    ipo-one-release-profile: closed-non-funds-pilot
  annotations:
    run.googleapis.com/default-url-disabled: "true"
    run.googleapis.com/ingress: internal-and-cloud-load-balancing
    run.googleapis.com/invoker-iam-disabled: "true"
spec:
  template:
    metadata:
      annotations:
        autoscaling.knative.dev/minScale: "1"
        autoscaling.knative.dev/maxScale: "5"
        run.googleapis.com/cloudsql-instances: ${CLOUD_SQL_CONNECTION_NAME}
        run.googleapis.com/execution-environment: gen2
        run.googleapis.com/startup-cpu-boost: "true"
    spec:
      containerConcurrency: 10
      timeoutSeconds: 30
      serviceAccountName: ${RUNTIME_SERVICE_ACCOUNT_EMAIL}
      containers:
        - name: ipo-one
          image: ${IMAGE_URI}
          command:
            - /nodejs/bin/node
          args:
            - apps/private-pilot/src/start-production.js
          ports:
            - name: http1
              containerPort: 8080
          env:
            - name: NODE_ENV
              value: production
            - name: PORT
              value: "8080"
            - name: IPO_ONE_ALLOWED_HOSTS
              value: ipo.one,www.ipo.one
            - name: IPO_ONE_PUBLIC_ORIGIN
              value: https://ipo.one
            - name: IPO_ONE_TRUST_PROXY
              value: "true"
            - name: IPO_ONE_DEPLOYMENT_MODE
              value: closed_pilot
            - name: IPO_ONE_RELEASE_ID
              value: ${RELEASE_SHA}
            - name: IPO_ONE_TENANT_ID
              value: ${TENANT_ID}
            - name: IPO_ONE_SYSTEM_ACTOR_ID
              value: ${SYSTEM_ACTOR_ID}
            - name: IPO_ONE_POLICY_VERSION
              value: security_001.v1
            - name: IPO_ONE_AUTHENTICATION_MODE
              value: closed_pilot
            - name: IPO_ONE_IDP_DEPLOYMENT_APPROVAL
              value: APPROVED
            - name: IPO_ONE_IDP_VENDOR_ID
              value: ${IDP_VENDOR_ID}
            - name: IPO_ONE_IDP_DEPLOYMENT_APPROVAL_SHA
              value: ${IDP_DEPLOYMENT_APPROVAL_SHA}
            - name: IPO_ONE_IDP_CONFIGURATION_REF
              value: projects/${PROJECT_ID}/secrets/ipo-one-identity-config/versions/${IDENTITY_CONFIG_VERSION}
            - name: IPO_ONE_OIDC_CLIENT_CREDENTIAL_REF
              value: projects/${PROJECT_ID}/secrets/ipo-one-google-oidc-client-secret/versions/${OIDC_CLIENT_SECRET_VERSION}
            - name: IPO_ONE_AUTH_REFERENCE_HASH_KEY_REF
              value: projects/${PROJECT_ID}/secrets/ipo-one-auth-reference-hash-key/versions/${AUTH_REFERENCE_HASH_KEY_VERSION}
            - name: IPO_ONE_AUTH_ENCRYPTION_KEY_REF
              value: projects/${PROJECT_ID}/secrets/ipo-one-auth-encryption-key/versions/${AUTH_ENCRYPTION_KEY_VERSION}
            - name: IPO_ONE_GATEWAY_DATABASE_URL
              valueFrom:
                secretKeyRef:
                  name: ipo-one-gateway-database-url
                  key: ${GATEWAY_DATABASE_URL_VERSION}
            - name: IPO_ONE_AUTH_DATABASE_URL
              valueFrom:
                secretKeyRef:
                  name: ipo-one-auth-database-url
                  key: ${AUTH_DATABASE_URL_VERSION}
            - name: IPO_ONE_AUTH_REFERENCE_HASH_KEY_FILE
              value: /var/run/secrets/ipo-one/auth-reference-hash-key/key
            - name: IPO_ONE_AUTH_ENCRYPTION_KEY_FILE
              value: /var/run/secrets/ipo-one/auth-encryption-key/key
            - name: IPO_ONE_OIDC_CLIENT_SECRET_FILE
              value: /var/run/secrets/ipo-one/google-oidc-client-secret/value
            - name: IPO_ONE_IDENTITY_CONFIG_FILE
              value: /var/run/secrets/ipo-one/identity-config/config.json
            - name: IPO_ONE_AGENT_MTLS_CONFIG_FILE
              value: /var/run/secrets/ipo-one/agent-mtls-config/config.json
            - name: IPO_ONE_EDGE_ASSERTION_KEY_FILE
              value: /var/run/secrets/ipo-one/edge-assertion-key/key
          resources:
            limits:
              cpu: "1"
              memory: 1Gi
          startupProbe:
            httpGet:
              path: /readyz
              port: 8080
            initialDelaySeconds: 0
            timeoutSeconds: 2
            failureThreshold: 30
            periodSeconds: 2
          livenessProbe:
            httpGet:
              path: /livez
              port: 8080
            initialDelaySeconds: 15
            timeoutSeconds: 2
            failureThreshold: 3
            periodSeconds: 10
          volumeMounts:
            - name: auth-reference-hash-key
              mountPath: /var/run/secrets/ipo-one/auth-reference-hash-key
            - name: auth-encryption-key
              mountPath: /var/run/secrets/ipo-one/auth-encryption-key
            - name: google-oidc-client-secret
              mountPath: /var/run/secrets/ipo-one/google-oidc-client-secret
            - name: identity-config
              mountPath: /var/run/secrets/ipo-one/identity-config
            - name: agent-mtls-config
              mountPath: /var/run/secrets/ipo-one/agent-mtls-config
            - name: edge-assertion-key
              mountPath: /var/run/secrets/ipo-one/edge-assertion-key
      volumes:
        - name: auth-reference-hash-key
          secret:
            secretName: ipo-one-auth-reference-hash-key
            items:
              - key: ${AUTH_REFERENCE_HASH_KEY_VERSION}
                path: key
        - name: auth-encryption-key
          secret:
            secretName: ipo-one-auth-encryption-key
            items:
              - key: ${AUTH_ENCRYPTION_KEY_VERSION}
                path: key
        - name: google-oidc-client-secret
          secret:
            secretName: ipo-one-google-oidc-client-secret
            items:
              - key: ${OIDC_CLIENT_SECRET_VERSION}
                path: value
        - name: identity-config
          secret:
            secretName: ipo-one-identity-config
            items:
              - key: ${IDENTITY_CONFIG_VERSION}
                path: config.json
        - name: agent-mtls-config
          secret:
            secretName: ipo-one-agent-mtls-config
            items:
              - key: ${AGENT_MTLS_CONFIG_VERSION}
                path: config.json
        - name: edge-assertion-key
          secret:
            secretName: ipo-one-edge-assertion-key
            items:
              - key: ${EDGE_ASSERTION_KEY_VERSION}
                path: key
  traffic:
    - percent: 100
      latestRevision: true
