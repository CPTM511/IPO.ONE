apiVersion: run.googleapis.com/v1
kind: Job
metadata:
  name: ipo-one-closed-pilot-migrate
  namespace: ${PROJECT_NUMBER}
  labels:
    cloud.googleapis.com/location: ${REGION}
    ipo-one-release-profile: closed-non-funds-pilot
spec:
  template:
    metadata:
      annotations:
        run.googleapis.com/cloudsql-instances: ${CLOUD_SQL_CONNECTION_NAME}
        run.googleapis.com/execution-environment: gen2
    spec:
      taskCount: 1
      template:
        spec:
          maxRetries: 0
          timeoutSeconds: "900"
          serviceAccountName: ${MIGRATION_SERVICE_ACCOUNT_EMAIL}
          containers:
            - name: migrate
              image: ${IMAGE_URI}
              command:
                - /nodejs/bin/node
              args:
                - scripts/migrate.mjs
                - up
              env:
                - name: NODE_ENV
                  value: production
                - name: DATABASE_URL
                  valueFrom:
                    secretKeyRef:
                      name: ipo-one-migration-database-url
                      key: ${MIGRATION_DATABASE_URL_VERSION}
