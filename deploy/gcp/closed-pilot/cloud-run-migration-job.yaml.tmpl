apiVersion: run.googleapis.com/v1
kind: Job
metadata:
  name: ipo-one-closed-pilot-migrate
  namespace: ${PROJECT_NUMBER}
  labels:
    cloud.googleapis.com/location: ${REGION}
    ipo-one-release-profile: closed-non-funds-pilot
spec:
  template:
    metadata:
      annotations:
        run.googleapis.com/cloudsql-instances: ${CLOUD_SQL_CONNECTION_NAME}
        run.googleapis.com/execution-environment: gen2
    spec:
      taskCount: 1
      template:
        spec:
          maxRetries: 0
          timeoutSeconds: "900"
          serviceAccountName: ${MIGRATION_SERVICE_ACCOUNT_EMAIL}
          containers:
            - name: bootstrap
              image: ${IMAGE_URI}
              command:
                - /nodejs/bin/node
              args:
                - apps/private-pilot/src/bootstrap-production.js
              env:
                - name: NODE_ENV
                  value: production
                - name: IPO_ONE_ADMIN_DATABASE_URL
                  valueFrom:
                    secretKeyRef:
                      name: ipo-one-migration-database-url
                      key: "${MIGRATION_DATABASE_URL_VERSION}"
                - name: IPO_ONE_BOOTSTRAP_CONFIG_FILE
                  value: /var/run/secrets/ipo-one/bootstrap-config/config.json
                - name: IPO_ONE_GATEWAY_DATABASE_PASSWORD_FILE
                  value: /var/run/secrets/ipo-one/gateway-database-password/value
                - name: IPO_ONE_AUTH_DATABASE_PASSWORD_FILE
                  value: /var/run/secrets/ipo-one/auth-database-password/value
                - name: IPO_ONE_AUTH_REFERENCE_HASH_KEY_FILE
                  value: /var/run/secrets/ipo-one/auth-reference-hash-key/key
              volumeMounts:
                - name: bootstrap-config
                  mountPath: /var/run/secrets/ipo-one/bootstrap-config
                - name: gateway-database-password
                  mountPath: /var/run/secrets/ipo-one/gateway-database-password
                - name: auth-database-password
                  mountPath: /var/run/secrets/ipo-one/auth-database-password
                - name: auth-reference-hash-key
                  mountPath: /var/run/secrets/ipo-one/auth-reference-hash-key
          volumes:
            - name: bootstrap-config
              secret:
                secretName: ipo-one-bootstrap-config
                items:
                  - key: "${BOOTSTRAP_CONFIG_VERSION}"
                    path: config.json
            - name: gateway-database-password
              secret:
                secretName: ipo-one-gateway-database-password
                items:
                  - key: "${GATEWAY_DATABASE_PASSWORD_VERSION}"
                    path: value
            - name: auth-database-password
              secret:
                secretName: ipo-one-auth-database-password
                items:
                  - key: "${AUTH_DATABASE_PASSWORD_VERSION}"
                    path: value
            - name: auth-reference-hash-key
              secret:
                secretName: ipo-one-auth-reference-hash-key
                items:
                  - key: "${AUTH_REFERENCE_HASH_KEY_VERSION}"
                    path: key
