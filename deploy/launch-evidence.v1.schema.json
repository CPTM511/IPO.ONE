{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ipo.one/operations/launch-evidence.v1.schema.json",
  "title": "IPO.ONE Launch Evidence v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "policyVersion",
    "profile",
    "release",
    "capabilities",
    "externalAuthorization",
    "gates"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ipo.one.launch-evidence/v1"
    },
    "policyVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "profile": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]{2,63}$"
    },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "commitSha",
        "ciRunUrl",
        "imageUri",
        "builtAt"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "maxLength": 128
        },
        "commitSha": {
          "type": "string",
          "pattern": "^[a-f0-9]{40}$"
        },
        "ciRunUrl": {
          "type": "string",
          "format": "uri",
          "maxLength": 2048
        },
        "imageUri": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._/-]*@sha256:[a-f0-9]{64}$",
          "maxLength": 512
        },
        "builtAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "capabilities": {
      "$ref": "#/$defs/capabilities"
    },
    "externalAuthorization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "system",
        "environment",
        "approvalUrl",
        "approvedAt"
      ],
      "properties": {
        "system": {
          "const": "protected_environment"
        },
        "environment": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{2,63}$"
        },
        "approvalUrl": {
          "type": "string",
          "format": "uri",
          "maxLength": 2048
        },
        "approvedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "gates": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "$ref": "#/$defs/gate"
      }
    }
  },
  "$defs": {
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "realFundsEnabled",
        "humanCreditEnabled",
        "privateTenantDataEnabled",
        "externalProviderExecutionEnabled"
      ],
      "properties": {
        "realFundsEnabled": {
          "type": "boolean"
        },
        "humanCreditEnabled": {
          "type": "boolean"
        },
        "privateTenantDataEnabled": {
          "type": "boolean"
        },
        "externalProviderExecutionEnabled": {
          "type": "boolean"
        }
      }
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "status",
        "ownerRole",
        "approvedBy",
        "approvedAt",
        "expiresAt",
        "evidenceUrl"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]{2,63}$"
        },
        "status": {
          "enum": [
            "pending",
            "approved",
            "rejected"
          ]
        },
        "ownerRole": {
          "type": "string",
          "maxLength": 128
        },
        "approvedBy": {
          "type": "string",
          "maxLength": 128
        },
        "approvedAt": {
          "type": "string",
          "format": "date-time"
        },
        "expiresAt": {
          "type": "string",
          "format": "date-time"
        },
        "evidenceUrl": {
          "type": "string",
          "format": "uri",
          "maxLength": 2048
        }
      }
    }
  }
}
