PORT=3000
HOST=127.0.0.1
DEMO_MODE=true
IPO_ONE_DEPLOYMENT_MODE=local_sandbox
IPO_ONE_PUBLIC_ORIGIN=http://127.0.0.1:3000
IPO_ONE_HSTS_MAX_AGE=0
IPO_ONE_RELEASE_SHA=local
IPO_ONE_TRUST_PROXY=false
# Durable mode and PostgreSQL tests only; keep credentials environment-local.
# DATABASE_URL=postgresql://localhost/ipo_one_test

# Managed public-sandbox runtime. These are documentation-only placeholders;
# deployment must use reviewed cloud configuration, never a committed .env file.
# NODE_ENV=production
# HOST=0.0.0.0
# PORT=8080
# IPO_ONE_ALLOWED_HOSTS=ipo.one,www.ipo.one
# IPO_ONE_DEPLOYMENT_MODE=public_sandbox
# IPO_ONE_HSTS_MAX_AGE=86400
# IPO_ONE_PUBLIC_ORIGIN=https://ipo.one
# IPO_ONE_PUBLIC_SANDBOX_ACK=I_UNDERSTAND_NO_REAL_FUNDS
# IPO_ONE_RELEASE_SHA=<immutable-git-sha>
# IPO_ONE_SECURITY_CONTACT=https://github.com/CPTM511/IPO.ONE/security
# IPO_ONE_TRUST_PROXY=true
